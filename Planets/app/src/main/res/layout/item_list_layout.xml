<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/teal_200"
    android:padding="16dp">
    <ImageView
        android:id="@+id/planeticon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/planetname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:text="Planet Name"
        app:layout_constraintBottom_toTopOf="@+id/planetposition"
        app:layout_constraintStart_toEndOf="@+id/planeticon"
        app:layout_constraintTop_toTopOf="@+id/planeticon"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/planetposition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:text="Planet Position"
        app:layout_constraintBottom_toBottomOf="@+id/planeticon"
        app:layout_constraintStart_toEndOf="@+id/planeticon"
        app:layout_constraintTop_toBottomOf="@+id/planetname" />
</androidx.constraintlayout.widget.ConstraintLayout>
